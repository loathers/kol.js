{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src/client/**/*", "vite.client.config.mts"]
}
