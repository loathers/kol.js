{
  "name": "kol.js",
  "version": "0.10.9",
  "main": "./dist/index.node.js",
  "types": "./dist/index.node.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "node": {
        "types": "./dist/index.node.d.ts",
        "import": "./dist/index.node.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "./domains/*": {
      "types": "./dist/domains/*.d.ts",
      "import": "./dist/domains/*.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "import": "./dist/proxy/index.js"
    },
    "./flags": {
      "types": "./dist/flags/SqliteFlagsBackend.d.ts",
      "import": "./dist/flags/SqliteFlagsBackend.js"
    }
  },
  "type": "module",
  "files": [
    "/dist"
  ],
  "repository": "https://github.com/loathers/kol.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.0.0",
    "data-of-loathing": ">=4.3.0",
    "eslint": "^10.0.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "undici": "^6.21.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "data-of-loathing": ">=4.3.0"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "chevrotain": "^12.0.0",
    "css-select": "^6.0.0",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "domhandler": "^5.0.3",
    "domutils": "^3.2.2",
    "emittery": "^1.1.0",
    "entities": "^7.0.1",
    "fetch-cookie": "^3.2.0",
    "htmlparser2": "^10.1.0",
    "image-size": "^2.0.2",
    "kol-rng": "3",
    "ofetch": "^1.5.1",
    "tough-cookie": "^6.0.0",
    "ts-dedent": "^2.2.0",
    "zod": "^4.4.3"
  }
}
