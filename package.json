{
  "name": "kol.js-monorepo",
  "private": true,
  "packageManager": "yarn@4.4.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace kolappse dev",
    "build": "yarn workspace kol.js build",
    "test": "yarn workspace kol.js test",
    "lint": "yarn workspace kol.js lint",
    "format": "yarn workspace kol.js format && yarn workspace kolappse format",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4"
  }
}
