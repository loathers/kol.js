{
  "name": "kol.js",
  "version": "0.9.1",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./domains/*": {
      "import": "./dist/domains/*.js",
      "types": "./dist/domains/*.d.ts"
    }
  },
  "type": "module",
  "files": [
    "/dist"
  ],
  "repository": "https://github.com/loathers/kol.js",
  "license": "MIT",
  "packageManager": "yarn@4.4.1",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.0.0",
    "data-of-loathing": "3.2",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "undici": "^6.21.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "data-of-loathing": "3.2"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "css-select": "^6.0.0",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "domhandler": "^5.0.3",
    "domutils": "^3.2.2",
    "emittery": "^1.1.0",
    "entities": "^7.0.1",
    "fetch-cookie": "^3.2.0",
    "htmlparser2": "^10.1.0",
    "image-size": "^2.0.2",
    "kol-rng": "3",
    "ofetch": "^1.5.1",
    "tough-cookie": "^6.0.0",
    "ts-dedent": "^2.2.0"
  }
}
